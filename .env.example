# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PORT: The port the server binds to. Railway injects this automatically;
# defaults to 3000 locally if unset.
# PORT=3000

# --- Persistence backend ---
# When SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are set, the datastore is
# persisted durably to Supabase (recommended for Railway, which has no
# persistent disk). The whole datastore lives in a single JSONB row in the
# `docuhub_state` table. Find these in the Supabase dashboard:
#   Project Settings → API → Project URL  and  service_role secret key.
# SUPABASE_URL="https://<project-ref>.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="<service_role secret key>"
#
# File binaries are offloaded to a private Supabase Storage bucket ("documents",
# auto-created at startup) and served via short-lived signed CDN URLs, instead
# of being kept inline in the datastore. No extra config needed.

# SESSION_SECRET: HMAC key for stateless signed-cookie sessions. Optional — it
# defaults to SUPABASE_SERVICE_ROLE_KEY (a stable secret) so logins already
# survive redeploys. Set this to rotate sessions or to decouple from Supabase.
# SESSION_SECRET="<a long random string>"

# DATA_DIR: Used ONLY when Supabase is not configured (local dev fallback).
# Directory for the JSON datastore (db.json). Defaults to ./data. If you deploy
# without Supabase, point this at a mounted persistent volume (e.g. /data) so
# data survives redeploys.
# DATA_DIR=/data

# NODE_ENV: Set to "production" to serve the prebuilt SPA from ./dist.
# The "npm start" script sets this for you.
# NODE_ENV=production

# ALLOWED_EMAIL_DOMAIN: Restrict Admin-created accounts to one email domain.
# On Cloudflare Workers this is set in wrangler.toml [vars] instead (not a
# secret). Only needed here for other deploy targets (e.g. Railway) or local
# dev. Unset = any valid email is accepted.
# ALLOWED_EMAIL_DOMAIN="avdp.org.sl"

# --- Transactional email (Resend) ---
# Without RESEND_API_KEY, emails are logged and skipped (no error).
# RESEND_API_KEY="<api key>"
# EMAIL_FROM="AVDP Document Management System <docs@yourdomain.com>"
#
# RESEND_SHARE_TEMPLATE_ID: Optional. When set, share and share-link emails
# (only those two) are sent using this Resend dashboard-authored template
# instead of this codebase's built-in HTML. All other emails (invites,
# password resets, approvals) are unaffected. Variables passed match the
# "Document Shared" template's placeholders: RECIPIENT_NAME, SENDER_NAME,
# DOCUMENT_NAME, DOCUMENT_META, PERSONAL_MESSAGE, SECURITY_NOTICE,
# EXPIRY_DATE, DOCUMENT_URL, CURRENT_YEAR.
# RESEND_SHARE_TEMPLATE_ID="<template id>"

# --- OAuth ("Sign in with Google/Microsoft") ---
# Optional alternative login method for accounts an Admin already created
# (matched by email) -- not a self-registration path. Redirect URIs to
# register with each provider:
#   Google:    <APP_URL>/api/auth/oauth/google/callback
#   Microsoft: <APP_URL>/api/auth/oauth/microsoft/callback
# GOOGLE_CLIENT_ID="<client id>"
# GOOGLE_CLIENT_SECRET="<client secret>"
# MICROSOFT_CLIENT_ID="<application (client) id>"
# MICROSOFT_CLIENT_SECRET="<client secret>"
# MICROSOFT_TENANT_ID="<directory (tenant) id>"  # optional; defaults to "common"

# --- External backup (Settings -> Backup) ---
# Mirrors file binaries + a full metadata snapshot to an S3-compatible
# bucket. Built for iDrive e2, but any S3-compatible provider works
# (Backblaze B2, Wasabi, Cloudflare R2, MinIO) -- just point ENDPOINT at it.
# On Cloudflare Workers, a nightly cron trigger runs this automatically
# once these are set (see wrangler.toml [triggers]); an Admin can also
# trigger it on demand from Settings.
# IDRIVE_ACCESS_KEY_ID="<access key id>"
# IDRIVE_SECRET_ACCESS_KEY="<secret access key>"
# IDRIVE_ENDPOINT="https://<id>.idrivee2-<region>.com"
# IDRIVE_BUCKET="<bucket name>"
# IDRIVE_REGION="us-east-1"  # optional; most S3-compatible providers ignore this
